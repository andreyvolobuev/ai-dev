# Скопируй в .env и заполни. В git НЕ попадает.
#
# Логика: секреты + всё, что зависит от твоей машины / твоего деплоя
# (handle тимлида, default channel, локальные пути к репам), живут
# здесь. Всё остальное — в config/*.yaml и индексируется. Раньше
# был дополнительный config/local.yaml — удалили, всё в одном месте.
#
# LLM.
# Проект использует Claude Max подписку через claude-agent-sdk — это обёртка
# над CLI `claude`, который ты уже залогинил на машине. API-ключ НЕ нужен.
# Если при запуске видишь "Please log in" от claude — это значит надо
# сделать `claude login` в терминале той же машины.

# --- Jira (self-hosted 2GIS) ---
JIRA_URL=https://jira.2gis.ru
# Personal Access Token (PAT) — обязательный. Создаётся в Jira → Profile →
# Personal Access Tokens. Используется как Bearer token (не Basic Auth),
# поэтому curl-эквивалент: -H "Authorization: Bearer <JIRA_TOKEN>"
JIRA_TOKEN=...
# JIRA_USER — опциональный, нужен только если хочешь использовать Basic Auth
# (устаревший способ). Для PAT-аутентификации оставь пустым или не указывай.
# JIRA_USER=your.name@2gis.ru

# --- GitLab (self-hosted 2GIS) ---
GITLAB_URL=https://gitlab.2gis.ru
GITLAB_TOKEN=...

# --- Chat provider ---
# Какой чат-адаптер поднимать. Сейчас реализован только mattermost;
# slack / telegram — placeholders, NotImplementedError пока адаптер
# не написан (см. src/virtual_dev/adapters/chat/).
CHAT_PROVIDER=mattermost

# --- Mattermost (self-hosted 2GIS) ---
# Внимание: домен НЕ mattermost.2gis.ru. Правильный — mm.2gis.one.
MATTERMOST_URL=https://mm.2gis.one
MATTERMOST_TOKEN=...
MATTERMOST_BOT_USERNAME=...
# Корп-MM за self-signed / внутренним CA — requests по дефолту валится с
# SSLError. В 2GIS ставим false (как poker-planning-bot). Правильный путь —
# указать путь до CA-bundle в MATTERMOST_SSL_CA_FILE и оставить verify=true.
MATTERMOST_SSL_VERIFY=false
# MATTERMOST_SSL_CA_FILE=/path/to/ca-bundle.pem

# --- Confluence (self-hosted 2GIS) ---
# Используется HTTP Basic-auth через `fetch_url`: бот шлёт
# `Authorization: Basic <base64(user:secret)>`. В качестве `secret`
# годится либо Personal Access Token (через User profile → Manage
# tokens), либо обычный пароль от учётки — Basic-auth их не
# различает. PAT предпочтительнее (можно ротейтить и отозвать).
# NB: тот же PAT, что в JIRA_TOKEN, на Confluence НЕ переиспользуется
# (даже если оба сервиса на одном Atlassian-стеке) — нужен отдельный.
CONFLUENCE_URL=https://confluence.2gis.ru
CONFLUENCE_USER=your.name@2gis.ru
CONFLUENCE_TOKEN=<PAT или пароль>

# --- Runtime ---
# Путь к БД SQLite (относительно корня проекта или абсолютный).
DB_URL=sqlite+aiosqlite:///./data/virtual_dev.db

# Корень, куда клонируем репо, у которых не указан local_path.
WORKSPACES_DIR=./workspaces

# Bot identity for commits / MRs. Push выполняется под твоим GitLab token'ом,
# но автор коммита — всегда бот, чтобы человек в blame/истории сразу видел
# "это писал ИИ".
DEV_GIT_AUTHOR_NAME=Virtual Dev
DEV_GIT_AUTHOR_EMAIL=virtual-dev@datamining.2gis.ru
DEV_BRANCH_PREFIX=ai-dev
DEV_MR_DRAFT=true

# как часто Reviewer ходит в GitLab
REVIEW_POLL_INTERVAL_SECONDS=180
# как часто DevOps
PIPELINE_POLL_INTERVAL_SECONDS=120
# для smoke-теста оставить false, иначе ночью ничего не придёт
COMMUNICATOR_RESPECT_WORKING_HOURS=false

# Web dashboard.
WEB_HOST=127.0.0.1
WEB_PORT=8080
# Bearer token required for POST /kill (and future destructive admin
# endpoints). Optional when WEB_HOST=127.0.0.1 — loopback callers go
# through. Required as soon as the dashboard is bound off-loopback.
ADMIN_TOKEN=

# Уровень логирования loguru.
LOG_LEVEL=INFO

# --- Deploy-specific (раньше жило в config/local.yaml) ---

# Mattermost handle тимлида / лида проекта — на него идут DM из
# `stuck` и `blocked` (а также эскалации reviewer/devops).
# Пустое значение → fallback на agents.yaml (там обычно тоже пусто, так
# что без ESCALATION_USER эскалация будет молча роняться в логи).
ESCALATION_USER=

# Default-канал для общих оповещений (например «Plan ready» пинги).
# Channel ID в Mattermost (32-символьная строка). Пустое значение →
# fallback на mappings.yaml.
DEFAULT_TEAM_CHANNEL=

# Per-machine пути к локальным checkout'ам репо. JSON-объект, ключ —
# repo key из repositories.yaml, значение — абсолютный путь. Пример:
# REPO_LOCAL_PATHS={"bellingshausen": "/Users/yourname/Documents/2gis/bellingshausen"}
# Пустое значение → клонируем в WORKSPACES_DIR/<key> при первом обращении.
REPO_LOCAL_PATHS={}
