# Скопируй в .env и заполни. В git НЕ попадает.
#
# Логика: секреты живут здесь, настройки без секретов — в config/*.yaml.
#
# LLM.
# Проект использует Claude Max подписку через claude-agent-sdk — это обёртка
# над CLI `claude`, который ты уже залогинил на машине. API-ключ НЕ нужен.
# Если при запуске видишь "Please log in" от claude — это значит надо
# сделать `claude login` в терминале той же машины.

# --- Jira (self-hosted 2GIS) ---
JIRA_URL=https://jira.2gis.ru
# Personal Access Token (PAT) — обязательный. Создаётся в Jira → Profile →
# Personal Access Tokens. Используется как Bearer token (не Basic Auth),
# поэтому curl-эквивалент: -H "Authorization: Bearer <JIRA_TOKEN>"
JIRA_TOKEN=...
# JIRA_USER — опциональный, нужен только если хочешь использовать Basic Auth
# (устаревший способ). Для PAT-аутентификации оставь пустым или не указывай.
# JIRA_USER=your.name@2gis.ru

# --- GitLab (self-hosted 2GIS) ---
GITLAB_URL=https://gitlab.2gis.ru
GITLAB_TOKEN=...

# --- Mattermost (self-hosted 2GIS) ---
MATTERMOST_URL=https://mattermost.2gis.ru
MATTERMOST_TOKEN=...
MATTERMOST_BOT_USERNAME=...

# --- Confluence (self-hosted 2GIS) ---
CONFLUENCE_URL=https://confluence.2gis.ru
CONFLUENCE_USER=your.name@2gis.ru
CONFLUENCE_TOKEN=...

# --- Runtime ---
# Путь к БД SQLite (относительно корня проекта или абсолютный).
DB_URL=sqlite+aiosqlite:///./data/virtual_dev.db

# Корень, куда клонируем репо, у которых не указан local_path.
WORKSPACES_DIR=./workspaces

# Bot identity for commits / MRs. Push выполняется под твоим GitLab token'ом,
# но автор коммита — всегда бот, чтобы человек в blame/истории сразу видел
# "это писал ИИ".
DEV_GIT_AUTHOR_NAME=Virtual Dev
DEV_GIT_AUTHOR_EMAIL=virtual-dev@datamining.2gis.ru
DEV_BRANCH_PREFIX=ai-dev
DEV_MR_DRAFT=true

# как часто Reviewer ходит в GitLab
REVIEW_POLL_INTERVAL_SECONDS=180
# как часто DevOps
PIPELINE_POLL_INTERVAL_SECONDS=120
# для smoke-теста оставить false, иначе ночью ничего не придёт
COMMUNICATOR_RESPECT_WORKING_HOURS=false

# Web dashboard.
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Уровень логирования loguru.
LOG_LEVEL=INFO
